set $mod Mod4

set $left_m "eDP-1"
set $right_m "DP-2"

set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"
set $ws7 "7"
set $ws8 "8"
set $ws9 "9"
set $ws10 "10"
set $ws11 "11"
set $ws12 "12"
set $ws13 "13"
set $ws14 "14"
set $ws15 "15"
set $ws16 "16"
set $ws17 "17"
set $ws18 "18"
set $ws19 "19"
set $ws20 "20"

set $refresh_i3blocks pkill -RTMIN+10 i3blocks

floating_modifier $mod
tiling_drag modifier titlebar

# class                 border  backgr. text    indicator child_border
client.focused          #e9e9e9 #e9e9e9 #111111 #002fff #007fff
client.focused_inactive #c8c8c8 #c8c8c8 #111111 #000000 #000000
client.unfocused        #c8c8c8 #c8c8c8 #111111 #000000 #000000
client.urgent           #d00000 #d00000 #111111 #000000 #000000
client.placeholder      #999999 #999999 #111111 #000000 #000000

client.background       #ffffff

bar {
  colors {
    background #000000
    statusline #007fff
    separator  #c6c6c4

    focused_workspace  #c6c6c4 #c6c6c4 #1c1c1c
    active_workspace   #c6c6c4 #000000 #007fff
    inactive_workspace #000000 #000000 #007fff
    urgent_workspace   #000000 #000000 #007fff
    binding_mode       #000000 #000000 #007fff
  }
  position top
  status_command i3blocks
}

font pango:Fixedsys 2 Monospaced 8.6

workspace $ws1 output $right_m
workspace $ws2 output $right_m
workspace $ws3 output $right_m
workspace $ws4 output $right_m
workspace $ws5 output $right_m
workspace $ws6 output $right_m
workspace $ws7 output $right_m
workspace $ws8 output $right_m
workspace $ws9 output $right_m
workspace $ws10 output $right_m
workspace $ws11 output $left_m
workspace $ws12 output $left_m
workspace $ws13 output $left_m
workspace $ws14 output $left_m
workspace $ws15 output $left_m
workspace $ws16 output $left_m
workspace $ws17 output $left_m
workspace $ws18 output $left_m
workspace $ws19 output $left_m
workspace $ws20 output $left_m

assign [class="org.mozilla.Thunderbird"] $ws11
assign [title="rss"] $ws12
assign [class="Spotify"] $ws13
assign [class="whatsdesk"] $ws14
assign [class="vesktop"] $ws15
assign [class="steam"] $ws16
assign [class="protonvpn-app"] $ws20

for_window [class="kcalc"] floating enable
for_window [class=".*"] border pixel 1

exec_always --no-startup-id autotiling
exec_always --no-startup-id sleep 2 && nitrogen --set-auto --random $HOME/Images/Wallpapers/wallpapers/ --head=0 &
exec_always --no-startup-id sleep 2 && nitrogen --set-auto --random $HOME/Images/Wallpapers/wallpapers/ --head=1 &

exec --no-startup-id thunderbird
exec --no-startup-id alacritty -T rss --hold -e canto-curses
exec --no-startup-id spotify
exec --no-startup-id protonvpn-app
exec --no-startup-id xss-lock --transfer-sleep-lock -- i3lock --nofork
exec --no-startup-id nm-applet
exec --no-startup-id setxkbmap -option caps:none; xmodmap -e "keycode 66 = Escape"
exec --no-startup-id gromit-mpx -o 1
exec --no-startup-id xset s off -dpms
exec --no-startup-id greenclip daemon
exec --no-startup-id flameshot
exec --no-startup-id picom

bindsym $mod+Alt_L exec flameshot gui

bindsym XF86MonBrightnessUp exec brightnessctl set +5%
bindsym XF86MonBrightnessDown exec brightnessctl set 5%-

bindsym XF86AudioRaiseVolume exec pactl set-sink-volume @DEFAULT_SINK@ +5% && $refresh_i3blocks
bindsym XF86AudioLowerVolume exec pactl set-sink-volume @DEFAULT_SINK@ -5% && $refresh_i3blocks
bindsym XF86AudioMute exec pactl set-sink-mute @DEFAULT_SINK@ toggle && $refresh_i3blocks
bindsym XF86AudioMicMute exec pactl set-source-mute @DEFAULT_SOURCE@ toggle && $refresh_i3blocks

bindsym $mod+1 workspace number $ws1
bindsym $mod+2 workspace number $ws2
bindsym $mod+3 workspace number $ws3
bindsym $mod+4 workspace number $ws4
bindsym $mod+5 workspace number $ws5
bindsym $mod+6 workspace number $ws6
