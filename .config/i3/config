bindsym $mod+Return exec alacritty --working-directory $HOME
bindsym $mod+space focus mode_toggle
# bindsym $mod+Tab
bindsym $mod+a exec kcalc
bindsym $mod+b exec chromium https://www.usevia.app/
bindsym $mod+c exec vesktop
bindsym $mod+d exec source $HOME/.bin/dmenu_run
# bindsym $mod+e
