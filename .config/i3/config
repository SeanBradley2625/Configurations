bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right
bindsym $mod+m exec qtws /usr/share/qtws-apps/google-maps/google-maps.qtws
bindsym $mod+n exec alacritty -T rss --hold -e newsboat
bindsym $mod+o exec setxkbmap us
bindsym $mod+p exec source $HOME/.bin/books $HOME/Books/
