# class                 border  backgr. text    indicator child_border
client.focused          #e9e9e9 #e9e9e9 #111111 #e9e9e9 #e9e9e9
client.focused_inactive #e9e9e9 #c8c8c8 #111111 #e9e9e9 #e9e9e9
client.unfocused        #e9e9e9 #c8c8c8 #111111 #e9e9e9 #e9e9e9
client.urgent           #e9e9e9 #d00000 #111111 #e9e9e9 #e9e9e9
client.placeholder      #e9e9e9 #999999 #111111 #e9e9e9 #e9e9e9

client.background       #ffffff

bar {
  colors {
    background #1c1c1c
    statusline #007fff
    separator  #c6c6c4

    focused_workspace  #EEEEEE #c8c8c8 #111111
    active_workspace   #e9e9e9 #e9e9e9 #111111
    inactive_workspace #e9e9e9 #e9e9e9 #111111
    urgent_workspace   #e9e9e9 #d00000 #111111
    binding_mode       #e9e9e9 #e9e9e9 #111111
  }
  position top
  status_command i3blocks
}

font pango:Fixedsys 2 Monospaced 9

exec_always --no-startup-id xset s off -dpms
#exec_always $HOME/.bin/komorebi
#bindsym $mod+k exec killall komorebi
exec_always $HOME/.bin/autotiling
exec_always nm-applet
exec_always setxkbmap gb
exec_always $HOME/.bin/greenclip daemon
exec_always gromit-mpx -o 1
exec_always setxkbmap -option caps:none; xmodmap -e "keycode 66 = Escape"

set $refresh_i3blocks pkill -RTMIN+10 i3blocks
bindsym XF86AudioRaiseVolume exec \
  --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ +5% && $refresh_i3blocks
bindsym XF86AudioLowerVolume exec \
  --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ -5% && $refresh_i3blocks
bindsym XF86AudioMute exec \
  --no-startup-id pactl set-sink-mute @DEFAULT_SINK@ toggle && $refresh_i3blocks
bindsym XF86AudioMicMute exec \
  --no-startup-id pactl set-source-mute @DEFAULT_SOURCE@ toggle && $refresh_i3blocks

bindsym $mod+p exec source $HOME/.bin/books.sh /home/senb/Books/
bindsym $mod+t exec /home/senb/.bin/toggle-touchpad.sh
bindsym $mod+Shift+m exec alacritty -e vim \
  /home/senb/.config/i3/config \
  /home/senb/.config/i3blocks/config \
  /home/senb/.vimrc \
  /home/senb/.config/alacritty/alacritty.toml \
  /home/senb/.config/picom/picom.conf
bindsym $mod+c exec discord
bindsym $mod+v exec source $HOME/.bin/greenclip_gui.sh
bindsym $mod+i exec firefox-esr
bindsym $mod+Shift+i exec firefox
bindsym $mod+s exec source $HOME/.bin/start_music.sh
bindsym $mod+b exec chromium https://www.usevia.app/
bindsym $mod+o exec setxkbmap us
bindsym $mod+Shift+o exec setxkbmap gb
